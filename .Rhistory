###############################################################################
# Project     : Sample Size – HBS
# Component   : Direct estimation and sample size calculation
#
# Objective
# ---------
# Define the complex sampling design of the Household Budget Survey (HBS) and:
#   1. Estimate the national mean per capita consumption.
#   2. Derive design parameters (DEFF, ICC, average cluster size).
#   3. Calculate sample sizes under a household cluster sampling scheme
#      using functions from the survey4sampling package.
#
# This script uses:
# - `srvyr` / `survey` for direct estimation under complex survey designs.
# - `survey4sampling` for sample size calculations consistent with
#   two-stage household sampling designs.
#
# Author(s) : Stalyn Guerrero, Andrés Gutiérrez
# Date      : 2026-01-19
#
# Inputs
# ------
# - data/HBS_HH_Expenses_Updated2026.xlsx
#
# Expected key variables:
# - Cluster        : Primary Sampling Unit (PSU)
# - Stratum        : Sampling stratum
# - final_weight   : Final household weight
# - hh_size        : Household size
# - Total_Expenses : Total household expenditure
# - District       : Geographic analysis domain
#
# Outputs
# -------
# - National mean of per capita consumption
# - Design parameters (DEFF, ICC)
# - Required sample sizes under different scenarios
###############################################################################
########################################
# 1. Environment setup                  #
########################################
# Full environment cleanup to ensure reproducibility
rm(list = ls(all.names = TRUE))
gc()
# Global printing options
options(
scipen = 999,              # Avoid scientific notation
digits = 4,                # Decimal precision
stringsAsFactors = FALSE
)
########################################
# 2. Load libraries                     #
########################################
# Data manipulation
library(dplyr)
library(data.table)
library(stringr)
# Complex survey analysis
library(survey)
library(srvyr)
library(samplesize4surveys)
# Input/output
library(openxlsx)
# Avoid name conflicts
select <- dplyr::select
########################################
# 3. Read inputs                        #
########################################
# Read household-level dataset
# One row per household is assumed
set_data <- openxlsx::read.xlsx(
"data/HBS_HH_Expenses_Updated2026.xlsx"
)
shiny::runApp()
runApp()
shiny::runApp()
runApp()
runApp()
shiny::runApp()
runApp()
shiny::tagList(
shiny::wellPanel(
h3("Módulo 3. Definir precisión"),
p("Ingrese amplitud y nivel de confianza. El valor de alpha se calcula automáticamente (alpha = 1 - confianza)."),
shiny::numericInput(
ns("amplitud"),
"Amplitud del intervalo de confianza:",
value = NA,
min = 0,
step = 0.001
),
shiny::selectInput(
ns("conf"),
"Nivel de confianza:",
choices = c(
"90%" = 0.90,
"95%" = 0.95,
"99%" = 0.99
),
selected = 0.95
),
hr(),
h4("Resultados de precisión"),
tableOutput(ns("resultados"))
)
)
runApp()
runApp()
runApp()
runApp()
runApp()
