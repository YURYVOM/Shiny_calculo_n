#-----------------------------
# Server
#-----------------------------
server <- function(input, output, session) {
  
  steps <- c("1. Objetivo inferencial", "2. Precisión", "3. Diseño muestral",
             "4. Dominios y publicación", 
             "5. Asignación DAM×AREA")
  
  observeEvent(input$btn_next, {
    cur <- input$steps
    i <- match(cur, steps)
    if (i < length(steps)) updateTabsetPanel(session, "steps", selected = steps[i + 1])
  })
  
  observeEvent(input$btn_back, {
    cur <- input$steps
    i <- match(cur, steps)
    if (i > 1) updateTabsetPanel(session, "steps", selected = steps[i - 1])
  })
  
  #-----------------------------
  # Cálculo n_total
  #-----------------------------
  n_total_calc <- reactive({
    # Validaciones
    if (input.obj != "impact" && input.prec == "power") {
      stop("Poder estadístico solo aplica si el objetivo es Cambio/Impacto.")
    }
    
    deff <- input$deff
    Ngl  <- input$N_global
    if (is.na(Ngl)) Ngl <- NULL
    
    # No respuesta
    nr <- input$nr
    
    if (input$obj %in% c("mean", "total") && input$has_sigma == "no") {
      stop("Para media/total necesitas σ. Suministra σ o usa un piloto/histórico.")
    }
    
    if (input$obj == "prop") {
      p <- if (input$has_p == "yes") input$p else 0.5
      if (input$prec == "e") {
        n0 <- get_n_from_ss(ss4p(p = p, e = input$e, conf = 0.95, deff = deff, N = Ngl))
      } else if (input$prec == "cv") {
        n0 <- get_n_from_ss(ss4p(p = p, cv = input$cv, conf = 0.95, deff = deff, N = Ngl))
      } else {
        stop("Para objetivo Proporción, la precisión debe ser e o CV.")
      }
      return(ceiling(inflate_nr(n0, nr)))
    }
    
    if (input$obj == "mean") {
      if (input$prec == "e") {
        n0 <- get_n_from_ss(ss4m(mu = input$mu, sigma = input$sigma, e = input$e, conf = 0.95, deff = deff, N = Ngl))
      } else if (input$prec == "cv") {
        n0 <- get_n_from_ss(ss4m(mu = input$mu, sigma = input$sigma, cv = input$cv, conf = 0.95, deff = deff, N = Ngl))
      } else {
        stop("Para objetivo Media, la precisión debe ser e o CV.")
      }
      return(ceiling(inflate_nr(n0, nr)))
    }
    
    if (input$obj == "total") {
      if (input$prec == "e") {
        n0 <- get_n_from_ss(ss4t(mu = input$mu, sigma = input$sigma, e = input$e, conf = 0.95, deff = deff, N = Ngl))
      } else if (input$prec == "cv") {
        n0 <- get_n_from_ss(ss4t(mu = input$mu, sigma = input$sigma, cv = input$cv, conf = 0.95, deff = deff, N = Ngl))
      } else {
        stop("Para objetivo Total, la precisión debe ser e o CV.")
      }
      return(ceiling(inflate_nr(n0, nr)))
    }
    
    # Impacto
    if (input$obj == "impact") {
      if (input$prec != "power") {
        stop("Para Impacto, selecciona 'Poder estadístico' en BLOQUE 2.")
      }
      alpha <- input$alpha
      power <- input$power
      two_sided <- input$two_sided
      if (input$impact_outcome == "prop") {
        if (input$impact_type == "diff") {
          n0 <- n_diff_prop(input$p1, input$p2, alpha, power, two_sided, deff)
        } else {
          n0 <- n_did_prop(input$p1, input$p2, alpha, power, two_sided, deff, input$did_inflate)
        }
      } else {
        if (input$impact_type == "diff") {
          n0 <- n_diff_mean(input$sigma_i, input$delta, alpha, power, two_sided, deff)
        } else {
          n0 <- n_did_mean(input$sigma_i, input$delta, alpha, power, two_sided, deff, input$did_inflate)
        }
      }
      # n0 es por grupo en diff; aquí reportamos total (2 grupos). Para DID se mantiene conservador.
      n_total <- 2 * ceiling(n0)
      return(ceiling(inflate_nr(n_total, input$nr)))
    }
    
    stop("Objetivo no soportado.")
  })
  
  #-----------------------------
  # Asignación DAM×AREA
  #-----------------------------
  allocation <- eventReactive(input$run, {
    
    n_total <- n_total_calc()
    min_cell <- input$min_cell
    
    if (input$alloc == "ipfp") {
      req(input$dam_file, input$area_file)
      
      dam_df  <- read_csv(input$dam_file$datapath, show_col_types = FALSE) %>%
        mutate(DAM = as.character(DAM))
      area_df <- read_csv(input$area_file$datapath, show_col_types = FALSE) %>%
        mutate(AREA = as.character(AREA))
      
      if (!all(c("DAM","prop") %in% names(dam_df)))  stop("Archivo DAM debe tener columnas: DAM, prop")
      if (!all(c("AREA","prop") %in% names(area_df))) stop("Archivo AREA debe tener columnas: AREA, prop")
      
      dam <- dam_df$DAM
      area <- area_df$AREA
      
      prop_d <- dam_df$prop / sum(dam_df$prop)
      prop_a <- area_df$prop / sum(area_df$prop)
      
      mat <- ipfp_allocate(n_total, dam, area, prop_d, prop_a)
      
      # redondeo preservando total
      v <- as.vector(mat)
      v_round <- round_preserve_total(v, n_total)
      mat_r <- matrix(v_round, nrow = length(dam), ncol = length(area),
                      dimnames = list(dam, area))
      
      # mínimo por celda (si se impone, puede violar total; aquí lo ajustamos reescalando de forma simple)
      if (min_cell > 0) {
        mat_r <- pmax(mat_r, min_cell)
        # ajustar total: si se pasó, recortar de celdas más grandes
        overflow <- sum(mat_r) - n_total
        if (overflow > 0) {
          idx <- order(as.vector(mat_r), decreasing = TRUE)
          vec <- as.vector(mat_r)
          k <- 1
          while (overflow > 0 && k <= length(vec)) {
            j <- idx[k]
            if (vec[j] > min_cell) {
              dec <- min(vec[j] - min_cell, overflow)
              vec[j] <- vec[j] - dec
              overflow <- overflow - dec
            }
            k <- k + 1
          }
          mat_r <- matrix(vec, nrow = nrow(mat_r), ncol = ncol(mat_r), dimnames = dimnames(mat_r))
        }
      }
      
      out <- as.data.frame(as.table(mat_r))
      names(out) <- c("DAM","AREA","n")
      return(out)
    }
    
    if (input$alloc %in% c("propN","equal","neyman")) {
      req(input$cells_file)
      cells <- read_csv(input$cells_file$datapath, show_col_types = FALSE) %>%
        mutate(DAM = as.character(DAM), AREA = as.character(AREA))
      
      if (!all(c("DAM","AREA") %in% names(cells))) stop("Tabla celdas debe tener columnas: DAM, AREA (y opcional N).")
      
      if (input$alloc == "equal") {
        K <- nrow(cells)
        n0 <- floor(n_total / K)
        r  <- n_total - n0*K
        cells$n <- n0
        if (r > 0) cells$n[seq_len(r)] <- cells$n[seq_len(r)] + 1
        cells$n <- pmax(cells$n, min_cell)
        # ajustar total si min_cell alteró suma
        diff <- sum(cells$n) - n_total
        if (diff != 0) {
          idx <- order(cells$n, decreasing = (diff > 0))
          i <- 1
          while (diff != 0 && i <= nrow(cells)) {
            if (diff > 0 && cells$n[idx[i]] > min_cell) { cells$n[idx[i]] <- cells$n[idx[i]] - 1; diff <- diff - 1 }
            if (diff < 0) { cells$n[idx[i]] <- cells$n[idx[i]] + 1; diff <- diff + 1 }
            i <- i + 1
          }
        }
        return(cells %>% select(DAM, AREA, n))
      }
      
      if (input$alloc == "propN") {
        if (!("N" %in% names(cells))) stop("Asignación proporcional requiere columna N por celda.")
        if (any(is.na(cells$N)) || any(cells$N <= 0)) stop("N debe ser >0 en todas las celdas.")
        w <- cells$N / sum(cells$N)
        n_raw <- n_total * w
        n_alloc <- floor(n_raw)
        r <- n_total - sum(n_alloc)
        if (r > 0) {
          ord <- order(n_raw - n_alloc, decreasing = TRUE)
          n_alloc[ord[seq_len(r)]] <- n_alloc[ord[seq_len(r)]] + 1
        }
        cells$n <- pmax(n_alloc, min_cell)
        # ajustar total si min_cell alteró suma
        diff <- sum(cells$n) - n_total
        if (diff > 0) {
          ord <- order(cells$n, decreasing = TRUE)
          i <- 1
          while (diff > 0 && i <= length(ord)) {
            j <- ord[i]
            if (cells$n[j] > min_cell) { cells$n[j] <- cells$n[j] - 1; diff <- diff - 1 }
            i <- i + 1
          }
        }
        return(cells %>% select(DAM, AREA, n))
      }
      
      if (input$alloc == "neyman") {
        stop("Neyman (óptimo) requiere varianzas por estrato/celda y, usualmente, costos. Stub listo para extender.")
      }
    }
    
    stop("Método de asignación no soportado.")
  })
  
  output$summary <- renderPrint({
    req(input$run)
    n_total <- n_total_calc()
    cat("n_total (ajustado por no respuesta):", n_total, "\n")
    cat("Asignación:", input$alloc, "\n")
    if (input$domain_level != "NAC") cat("Nivel de publicación/precisión declarado:", input$domain_level, "\n")
    if (input$hh == "yes") {
      cat("Encuesta de hogares multietápica: Sí\n")
      cat("DEFF:", input$deff, " | Tamaño hogar:", input$hh_size, " | Elegibilidad:", input$elig, "\n")
    } else {
      cat("MAS / diseño simple\n")
      cat("DEFF:", input$deff, "\n")
    }
  })
  
  output$tbl_out <- renderDT({
    req(allocation())
    datatable(allocation(), options = list(pageLength = 15))
  })
  
  output$download <- downloadHandler(
    filename = function() paste0("asignacion_DAM_AREA_", Sys.Date(), ".csv"),
    content = function(file) {
      req(allocation())
      write_csv(allocation(), file)
    }
  )
}

