#-----------------------------
# Helpers
#-----------------------------
get_n_from_ss <- function(obj) {
  x <- unlist(obj)
  x <- x[is.finite(x)]
  if (length(x) == 0) stop("No pude extraer n del resultado ss4*().")
  as.numeric(x[1])
}

inflate_nr <- function(n, r) {
  if (is.null(r) || is.na(r) || r <= 0) return(n)
  if (r >= 1) stop("No respuesta debe estar en (0,1).")
  n / (1 - r)
}

# Impacto: diferencia simple (dos grupos independientes), aproximación normal
n_diff_prop <- function(p1, p2, alpha = 0.05, power = 0.80, two_sided = TRUE, deff = 1) {
  z_alpha <- qnorm(1 - alpha/ifelse(two_sided, 2, 1))
  z_beta  <- qnorm(power)
  
  pbar <- (p1 + p2) / 2
  num  <- (z_alpha * sqrt(2 * pbar * (1 - pbar)) + z_beta * sqrt(p1*(1-p1) + p2*(1-p2)))^2
  den  <- (p1 - p2)^2
  n    <- num / den
  n * deff
}

n_diff_mean <- function(sigma, delta, alpha = 0.05, power = 0.80, two_sided = TRUE, deff = 1) {
  z_alpha <- qnorm(1 - alpha/ifelse(two_sided, 2, 1))
  z_beta  <- qnorm(power)
  
  n <- 2 * ( (z_alpha + z_beta) * sigma / delta )^2
  n * deff
}

# Doble diferencia: aproximación conservadora (multiplica varianza efectiva).
# Nota: DID real depende de correlación intra-individuo/cluster y diseño longitudinal/panel.
n_did_prop <- function(p1, p2, alpha = 0.05, power = 0.80, two_sided = TRUE, deff = 1, inflate_factor = 2) {
  # Conservador: toma n de diff simple y multiplica por factor (por defecto 2).
  n_diff_prop(p1, p2, alpha, power, two_sided, deff) * inflate_factor
}
n_did_mean <- function(sigma, delta, alpha = 0.05, power = 0.80, two_sided = TRUE, deff = 1, inflate_factor = 2) {
  n_diff_mean(sigma, delta, alpha, power, two_sided, deff) * inflate_factor
}

# IPFP allocation: margenes DAM y AREA (proporciones o totales)
ipfp_allocate <- function(n_total, dam, area, prop_dam, prop_area, seed = NULL, tol = 1e-8, maxiter = 2000) {
  stopifnot(length(dam) > 0, length(area) > 0)
  D <- length(dam); A <- length(area)
  
  if (is.null(seed)) seed <- matrix(1, nrow = D, ncol = A)
  
  targ_d <- n_total * prop_dam
  targ_a <- n_total * prop_area
  
  res <- mipfp::Ipfp(seed = seed,
                     target.list = list(1, 2),
                     target.data = list(targ_d, targ_a),
                     tol = tol, iter = maxiter)
  
  mat <- res$x.hat
  dimnames(mat) <- list(dam, area)
  mat
}

# Redondeo preservando suma total (no preserva margenes exactos; si requieres margenes exactos, se implementa ajuste iterativo)
round_preserve_total <- function(x, total) {
  xf <- floor(x)
  r  <- total - sum(xf)
  if (r > 0) {
    ord <- order(x - xf, decreasing = TRUE)
    xf[ord[seq_len(r)]] <- xf[ord[seq_len(r)]] + 1
  }
  xf
}

